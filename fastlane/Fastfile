# Fastlane: build the iOS app and ship it to TestFlight.
# Auth is via an App Store Connect API key (no Apple ID / password). All inputs
# come from environment variables provided as GitHub Actions secrets.

default_platform(:ios)

APP_ID = "com.brandonlines.mexicanrummy"
PROJECT = "ios/App/App.xcodeproj"

platform :ios do
  desc "Build and upload a new build to TestFlight"
  lane :beta do
    # Ephemeral keychain for CI so cloud-managed signing certs can be stored.
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_CONTENT"),
      is_key_content_base64: true,
      in_house: false
    )

    # Monotonic build number = (highest build already on TestFlight) + 1.
    next_build = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: APP_ID,
      initial_build_number: 0
    ) + 1

    build_app(
      project: PROJECT,
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      output_name: "App.ipa",
      clean: true,
      # Cloud-managed automatic signing via the API key (no .p12 / profiles to manage).
      # CURRENT_PROJECT_VERSION override sets CFBundleVersion ($(CURRENT_PROJECT_VERSION)).
      xcargs: "-allowProvisioningUpdates CURRENT_PROJECT_VERSION=#{next_build} DEVELOPMENT_TEAM=#{ENV.fetch('APPLE_TEAM_ID')}",
      export_options: {
        teamID: ENV.fetch("APPLE_TEAM_ID"),
        signingStyle: "automatic"
      }
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_ID,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
